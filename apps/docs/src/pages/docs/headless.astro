    ]}
  />

  <p><strong>Returns:</strong></p>

  <DocsTable
    headers={['Property', 'Type', 'Description']}
    rows={[
      ['<code>tableState</code>', '<code>TableState&lt;T&gt;</code>', 'Full state snapshot (see below)'],
      ['<code>handleSort</code>', '<code>(action: SortAction&lt;T&gt;) =&gt; void</code>', 'Dispatch a sort change'],
      ['<code>handleSelectAllRows</code>', '<code>(action: AllRowsAction&lt;T&gt;) =&gt; void</code>', 'Dispatch select/deselect all'],
      ['<code>handleSelectedRow</code>', '<code>(action: SingleRowAction&lt;T&gt;) =&gt; void</code>', 'Dispatch a single row toggle'],
