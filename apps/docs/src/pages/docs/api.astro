      ['<code>context</code>', '<code>background</code>, <code>text</code>'],
      ['<code>divider</code>', '<code>default</code>'],
      ['<code>button</code>', '<code>default</code>, <code>hover</code>, <code>focus</code>, <code>disabled</code>'],
      ['<code>selected</code>', '<code>default</code>, <code>text</code>'],
      ['<code>highlightOnHover</code>', '<code>default</code>, <code>text</code>'],
