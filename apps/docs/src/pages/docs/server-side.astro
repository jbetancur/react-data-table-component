---
import DocsLayout from '../../layouts/DocsLayout.astro';
import Demo from '../../components/Demo.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import ServerSideDemo from '../../components/demos/ServerSideDemo.tsx';
---

<DocsLayout title="Server-side data | react-data-table-component">
  <h1>Server-side data</h1>

  <p>
    For large datasets, move sorting and pagination to the server.
    Set <code>paginationServer</code> (and optionally <code>sortServer</code>)
    and respond to the change callbacks.
  </p>

  <Demo
    title="Server-side pagination, sorting, and search"
    description="200-row simulated dataset with 350 ms fake network latency. Try sorting, changing pages, and searching."
    code={`import { useState, useEffect, useCallback } from 'react';
import DataTable, { type TableColumn, type SortOrder } from 'react-data-table-component';

interface User {
  id: number;
  name: string;
  department: string;
  salary: number;
  status: string;
}

const columns: TableColumn<User>[] = [
  { id: 'name',   name: 'Name',       selector: r => r.name,       sortable: true, sortField: 'name' },
  { id: 'dept',   name: 'Department', selector: r => r.department, sortable: true, sortField: 'department' },
  { id: 'salary', name: 'Salary',     selector: r => r.salary,     sortable: true, sortField: 'salary',
    right: true, format: r => \`$\${r.salary.toLocaleString()}\` },
  { id: 'status', name: 'Status',     selector: r => r.status,     sortable: true, sortField: 'status' },
];

export default function ServerSideTable() {
  const [data, setData]           = useState<User[]>([]);
  const [loading, setLoading]     = useState(false);
  const [totalRows, setTotal]     = useState(0);
  const [perPage, setPerPage]     = useState(10);
  const [page, setPage]           = useState(1);
  const [sortField, setSortField] = useState('name');
  const [sortDir, setSortDir]     = useState<SortOrder>('asc');
  const [search, setSearch]       = useState('');
  const [resetPage, setResetPage] = useState(false);

  const fetchData = useCallback(async (params: {
    page: number; perPage: number; sortField: string;
    sortDir: SortOrder; search: string;
  }) => {
    setLoading(true);
    const p = new URLSearchParams({
      page: String(params.page), limit: String(params.perPage),
      sort: params.sortField,    dir:   params.sortDir,
      q:    params.search,
    });
    const res  = await fetch(\`/api/users?\${p}\`);
    const json = await res.json();
    setData(json.rows);
    setTotal(json.total);
    setLoading(false);
  }, []);

  useEffect(() => {
    fetchData({ page, perPage, sortField, sortDir, search });
  }, []); // eslint-disable-line react-hooks/exhaustive-deps

  function handlePageChange(p: number) {
    setPage(p);
    fetchData({ page: p, perPage, sortField, sortDir, search });
  }

  function handlePerPageChange(pp: number, p: number) {
    setPerPage(pp);
    fetchData({ page: p, perPage: pp, sortField, sortDir, search });
  }

  function handleSort(col: TableColumn<User>, dir: SortOrder) {
    const field = col.sortField ?? 'name';
    setSortField(field); setSortDir(dir);
    fetchData({ page, perPage, sortField: field, sortDir: dir, search });
  }

  function handleSearch(e: React.ChangeEvent<HTMLInputElement>) {
    const q = e.target.value;
    setSearch(q);
    setResetPage(prev => !prev); // resets pagination to page 1
    fetchData({ page: 1, perPage, sortField, sortDir, search: q });
  }

  return (
    <div>
      <input type="search" placeholder="Search…" value={search} onChange={handleSearch} />
      <DataTable
        columns={columns}
        data={data}
        progressPending={loading}
        pagination
        paginationServer
        paginationTotalRows={totalRows}
        paginationResetDefaultPage={resetPage}
        onChangePage={handlePageChange}
        onChangeRowsPerPage={handlePerPageChange}
        sortServer
        onSort={handleSort}
        highlightOnHover
      />
    </div>
  );
}`}
  >
    <ServerSideDemo client:load />
  </Demo>

  <h2>With React Query</h2>

  <p>
    If you're already using <a href="https://tanstack.com/query" target="_blank" rel="noopener">TanStack Query</a>,
    let it own the fetch and pass its state into the table.
    <code>keepPreviousData</code> prevents an empty flash between page transitions.
  </p>

  <CodeBlock code={`import { useState } from 'react';
import { useQuery, keepPreviousData } from '@tanstack/react-query';
import DataTable, { type TableColumn, type SortOrder } from 'react-data-table-component';

interface User { id: number; name: string; email: string; }

const fetcher = (page: number, perPage: number, sortField: string, sortDir: SortOrder, search: string) => {
  const p = new URLSearchParams({
    page: String(page), limit: String(perPage),
    sort: sortField, dir: sortDir, q: search,
  });
  return fetch(\`/api/users?\${p}\`).then(r => r.json());
};

export default function UsersTableQuery() {
  const [page, setPage]           = useState(1);
  const [perPage, setPerPage]     = useState(10);
  const [sortField, setSortField] = useState('name');
  const [sortDir, setSortDir]     = useState<SortOrder>('asc');
  const [search, setSearch]       = useState('');

  const { data, isLoading } = useQuery({
    queryKey: ['users', page, perPage, sortField, sortDir, search],
    queryFn:  () => fetcher(page, perPage, sortField, sortDir, search),
    placeholderData: keepPreviousData,
  });

  return (
    <DataTable
      columns={columns}
      data={data?.rows ?? []}
      progressPending={isLoading}
      pagination
      paginationServer
      paginationTotalRows={data?.total ?? 0}
      onChangePage={setPage}
      onChangeRowsPerPage={(pp) => { setPerPage(pp); setPage(1); }}
      sortServer
      onSort={(col, dir) => {
        setSortField(col.sortField ?? 'name');
        setSortDir(dir);
        setPage(1);
      }}
    />
  );
}`} lang="tsx" />

  <h2>With SWR</h2>

  <CodeBlock code={`import { useState } from 'react';
import useSWR from 'swr';
import DataTable, { type TableColumn, type SortOrder } from 'react-data-table-component';

const fetcher = (url: string) => fetch(url).then(r => r.json());

export default function UsersTableSWR() {
  const [page, setPage]       = useState(1);
  const [perPage, setPerPage] = useState(10);
  const [sort, setSort]       = useState({ field: 'name', dir: 'asc' as SortOrder });

  const url = \`/api/users?page=\${page}&limit=\${perPage}&sort=\${sort.field}&dir=\${sort.dir}\`;
  const { data, isLoading } = useSWR(url, fetcher);

  return (
    <DataTable
      columns={columns}
      data={data?.rows ?? []}
      progressPending={isLoading}
      pagination
      paginationServer
      paginationTotalRows={data?.total ?? 0}
      onChangePage={setPage}
      onChangeRowsPerPage={(pp) => { setPerPage(pp); setPage(1); }}
      sortServer
      onSort={(col, dir) => {
        setSort({ field: col.sortField ?? 'name', dir });
        setPage(1);
      }}
    />
  );
}`} lang="tsx" />

  <h2>sortField on column definitions</h2>

  <p>
    Set <code>sortField</code> on each sortable column to control the identifier passed to
    your <code>onSort</code> callback. This lets your API field names differ from your
    TypeScript property names:
  </p>

  <CodeBlock code={`const columns: TableColumn<User>[] = [
  {
    name: 'Full name',
    selector: r => r.name,     // used for display
    sortable: true,
    sortField: 'full_name',    // passed to onSort — matches your API/DB column name
  },
];

function handleSort(column: TableColumn<User>, direction: SortOrder) {
  // column.sortField === 'full_name'
  fetchData({ sort: column.sortField, dir: direction });
}`} lang="tsx" />

  <h2>Resetting to page 1</h2>

  <p>
    When the dataset changes (e.g. after a search), reset pagination to page 1 by toggling
    <code>paginationResetDefaultPage</code>:
  </p>

  <CodeBlock code={`const [resetPage, setResetPage] = useState(false);

function handleSearch(q: string) {
  setResetPage(prev => !prev); // any change to this value triggers the reset
  fetchData({ query: q, page: 1 });
}

<DataTable
  ...
  paginationResetDefaultPage={resetPage}
/>`} lang="tsx" />

  <h2>Persisting selection across pages</h2>

  <p>
    By default, selecting rows on page 1 and then changing to page 2 resets the selection.
    Use <code>paginationServerOptions</code> to retain selections:
  </p>

  <CodeBlock code={`<DataTable
  paginationServer
  paginationServerOptions={{
    persistSelectedOnPageChange: true,
    persistSelectedOnSort: true,
  }}
/>`} lang="tsx" />

  <h2>Handling large row counts</h2>

  <p>
    Pass <code>paginationTotalRows</code> so the pagination component knows how many pages exist.
    This is separate from <code>data.length</code>, which only reflects the current page.
  </p>

  <CodeBlock code={`<DataTable
  data={currentPageRows}          // only the rows for this page
  paginationTotalRows={50000}     // total in the dataset
  paginationServer
  pagination
/>`} lang="tsx" />
</DocsLayout>
