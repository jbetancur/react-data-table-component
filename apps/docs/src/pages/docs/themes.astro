---
import DocsLayout from '../../layouts/DocsLayout.astro';
import Demo from '../../components/Demo.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import ThemesDemo from '../../components/demos/ThemesDemo.tsx';
import ColumnSeparatorsDemo from '../../components/demos/ColumnSeparatorsDemo.tsx';
---

<DocsLayout title="Themes | react-data-table-component">
  <h1>Themes</h1>

  <p>
    Pass a <code>theme</code> prop to switch between built-in named themes.
    Create your own with <code>createTheme()</code>.
  </p>

  <Demo
    title="Built-in themes"
    description="11 themes including dark variants and a custom 'ocean' theme created with createTheme()."
    code={`import DataTable, { createTheme } from 'react-data-table-component';

// Register a custom theme (inherits from 'dark')
createTheme('ocean', {
  text:             { primary: '#e0f2fe', secondary: '#7dd3fc' },
  background:       { default: '#0c4a6e' },
  divider:          { default: '#075985' },
  highlightOnHover: { default: '#075985', text: '#f0f9ff' },
}, 'dark');

<DataTable columns={columns} data={data} theme="ocean" />`}
  >
    <ThemesDemo client:load />
  </Demo>

  <h2>Built-in themes</h2>
  <table>
    <thead><tr><th>Name</th><th>Style</th></tr></thead>
    <tbody>
      <tr><td><code>default</code></td><td>Clean light (same as <code>light</code>)</td></tr>
      <tr><td><code>dark</code></td><td>Dark gray background</td></tr>
      <tr><td><code>material</code></td><td>Google Material Design, blue accent</td></tr>
      <tr><td><code>material-dark</code></td><td>Material dark variant</td></tr>
      <tr><td><code>slate</code></td><td>Clean, neutral blue-grey</td></tr>
      <tr><td><code>slate-dark</code></td><td>Slate dark variant</td></tr>
      <tr><td><code>ocean</code></td><td>Calm cyan-teal tones</td></tr>
      <tr><td><code>ocean-dark</code></td><td>Ocean dark variant</td></tr>
      <tr><td><code>midnight</code></td><td>GitHub-style deep dark, blue accent</td></tr>
      <tr><td><code>solarized</code></td><td>Classic Solarized terminal dark</td></tr>
    </tbody>
  </table>

  <h2>createTheme(name, overrides, inherit?)</h2>
  <p>
    Registers a named theme globally. Pass a parent theme name as the third argument to
    inherit its defaults and only override what you need.
  </p>
  <CodeBlock code={`createTheme('brand', {
  text:             { primary: '#1a1a2e', secondary: '#4a4a6a' },
  background:       { default: '#f0f4ff' },
  divider:          { default: '#c7d2fe' },
  selected:         { default: '#e0e7ff', text: '#1a1a2e' },
  highlightOnHover: { default: '#e8edff', text: '#1a1a2e' },
  button:           { default: '#4f46e5', hover: '#4338ca', disabled: '#c7d2fe' },
  striped:          { default: '#f5f7ff', text: '#1a1a2e' },
}); // inherits from 'default'`} lang="ts" />

  <h2>CSS variable override</h2>
  <p>
    Themes compile to CSS custom properties on <code>.rdt_table</code>. You can override
    any variable without calling <code>createTheme()</code> — scope to a wrapper class
    to avoid leaking to other tables on the page.
  </p>
  <CodeBlock code={`.my-table {
  --rdt-color-text-primary:   #1a1a2e;
  --rdt-color-bg:             #f0f4ff;
  --rdt-color-divider:        #c7d2fe;
  --rdt-color-highlight:      #e0e7ff;
  --rdt-color-selected:       #ede9fe;
}`} lang="css" />

  <h3>All CSS variables</h3>
  <table>
    <thead><tr><th>Variable</th><th>Default (light)</th><th>What it controls</th></tr></thead>
    <tbody>
      <tr><td><code>--rdt-color-text-primary</code></td><td><code>rgba(0,0,0,.87)</code></td><td>Primary text — rows, header cells</td></tr>
      <tr><td><code>--rdt-color-text-secondary</code></td><td><code>rgba(0,0,0,.54)</code></td><td>Muted text — group labels, pagination label</td></tr>
      <tr><td><code>--rdt-color-bg</code></td><td><code>#fff</code></td><td>Table, row, and header background</td></tr>
      <tr><td><code>--rdt-color-divider</code></td><td><code>rgba(0,0,0,.12)</code></td><td>Row borders and header border</td></tr>
      <tr><td><code>--rdt-color-scheme</code></td><td><code>light</code></td><td>CSS <code>color-scheme</code> — controls native checkbox/select rendering</td></tr>
      <tr><td><code>--rdt-color-striped</code></td><td><code>#fafafa</code></td><td>Striped row background</td></tr>
      <tr><td><code>--rdt-color-striped-text</code></td><td><code>rgba(0,0,0,.87)</code></td><td>Striped row text</td></tr>
      <tr><td><code>--rdt-color-selected</code></td><td><code>#e3f2fd</code></td><td>Selected row background</td></tr>
      <tr><td><code>--rdt-color-selected-text</code></td><td><code>rgba(0,0,0,.87)</code></td><td>Selected row text</td></tr>
      <tr><td><code>--rdt-color-highlight</code></td><td><code>#eee</code></td><td>Hover highlight background</td></tr>
      <tr><td><code>--rdt-color-highlight-text</code></td><td><code>rgba(0,0,0,.87)</code></td><td>Hover highlight text</td></tr>
      <tr><td><code>--rdt-color-btn</code></td><td><code>rgba(0,0,0,.54)</code></td><td>Sort icons, expander chevron, pagination button icons</td></tr>
      <tr><td><code>--rdt-color-btn-hover</code></td><td><code>rgba(0,0,0,.08)</code></td><td>Pagination button hover background</td></tr>
      <tr><td><code>--rdt-color-btn-focus</code></td><td><code>rgba(0,0,0,.12)</code></td><td>Pagination button focus background</td></tr>
      <tr><td><code>--rdt-color-btn-disabled</code></td><td><code>rgba(0,0,0,.18)</code></td><td>Pagination button disabled icon color</td></tr>
      <tr><td><code>--rdt-col-sep-color</code></td><td>falls back to <code>--rdt-color-divider</code></td><td>Column separator line color only — overrides divider for separators without affecting borders</td></tr>
    </tbody>
  </table>

  <h2>Column separators</h2>
  <p>
    Header separators are always visible. Use <code>columnSeparator</code> to also show them
    on body rows.
  </p>

  <Demo
    title="Column separators"
    description="Headers always have separators. Toggle body separators with the prop."
    code={`// No body separators (default). Headers still show separators
<DataTable columns={columns} data={data} />

// Subtle body separators (60%-height inset)
<DataTable columns={columns} data={data} columnSeparator />

// Full-height body separators
<DataTable columns={columns} data={data} columnSeparator="full" />`}
  >
    <ColumnSeparatorsDemo client:load />
  </Demo>
</DocsLayout>
