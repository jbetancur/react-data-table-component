---
import Layout from '../layouts/Layout.astro';

const GH_SPONSORS = 'https://github.com/sponsors/jbetancur';
const OC_BASE = 'https://opencollective.com/react-data-table-component';
---

<Layout
  title="Support — react-data-table-component"
  description="Priority support plans and sponsorship options for react-data-table-component."
>
  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-6 pt-20 pb-12 text-center">
    <h1 class="text-4xl font-bold tracking-tight text-gray-900">Support &amp; Sponsorship</h1>
    <p class="mt-4 text-lg text-gray-500 max-w-xl mx-auto">
      This library is maintained by one person. Your support funds bug fixes, new features, and keeps
      pace with the React ecosystem.
    </p>
  </section>

  <!-- Sponsor tiers -->
  <section class="bg-gray-50 py-16">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-2xl font-bold text-gray-900 text-center mb-10">Sponsorship Tiers</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
        {[
          {
            name: '☕ Supporter',
            price: '$5',
            period: '/mo',
            perks: ['Name in README supporters list'],
            amount: 5,
          },
          {
            name: '🎗 Backer',
            price: '$20',
            period: '/mo',
            perks: ['Name + link in README'],
            amount: 20,
          },
          {
            name: '🥉 Bronze',
            price: '$100',
            period: '/mo',
            perks: ['Small logo on docs site footer', 'Name + link in README'],
            amount: 100,
          },
          {
            name: '🥈 Silver',
            price: '$200',
            period: '/mo',
            perks: ['Medium logo on docs site sidebar', 'Logo + link in README'],
            amount: 200,
          },
          {
            name: '🥇 Gold',
            price: '$500',
            period: '/mo',
            perks: ['Large logo — hero spot on reactdatatable.com', 'Top placement in README', 'Limited to 3 sponsors'],
            amount: 500,
          },
        ].map(({ name, price, period, perks }) => (
          <div class="bg-white border border-gray-200 rounded-xl p-5 flex flex-col">
            <div class="font-semibold text-gray-900">{name}</div>
            <div class="mt-1 text-2xl font-bold text-gray-900">
              {price}<span class="text-sm font-normal text-gray-400">{period}</span>
            </div>
            <ul class="mt-3 flex-1 space-y-1.5 text-xs text-gray-500">
              {perks.map((p) => (
                <li class="flex items-start gap-1.5">
                  <svg class="mt-0.5 shrink-0 text-brand-500" width="12" height="12" viewBox="0 0 16 16" fill="none">
                    <path d="M3 8l3.5 3.5L13 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {p}
                </li>
              ))}
            </ul>
            <a
              href={GH_SPONSORS}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-4 block text-center border border-brand-200 text-brand-700 text-xs font-medium px-3 py-2 rounded-lg hover:bg-brand-50 transition-colors"
            >
              Sponsor on GitHub →
            </a>
          </div>
        ))}
      </div>

      <!-- One-time -->
      <div class="mt-8 bg-white border border-gray-200 rounded-xl p-6 text-center">
        <h3 class="font-semibold text-gray-900 mb-1">One-time donation</h3>
        <p class="text-sm text-gray-500 mb-4">No commitment. Every bit helps.</p>
        <a
          href={GH_SPONSORS}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-brand-600 text-white text-sm font-medium px-5 py-2 rounded-lg hover:bg-brand-700 transition-colors"
        >
          Sponsor on GitHub →
        </a>
        <p class="mt-3 text-xs text-gray-400">
          Prefer invoicing? <a href={`${OC_BASE}/donate`} target="_blank" rel="noopener noreferrer" class="underline hover:text-gray-600">Open Collective</a> provides receipts automatically.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-2xl mx-auto px-6 py-16">
    <h2 class="text-xl font-bold text-gray-900 mb-8 text-center">Common questions</h2>
    <dl class="space-y-6">
      {[
        {
          q: 'Does the library stay free?',
          a: 'Yes — always. The core library is MIT licensed. Sponsorship funds maintenance; it doesn\'t change what\'s free.',
        },
        {
          q: 'Can I get help with a complex integration?',
          a: 'Yes — email me directly to discuss one-off consulting. I\'m available for integrations, performance issues, and major version upgrades.',
        },
        {
          q: 'How does logo placement work?',
          a: 'Email me after subscribing at the Bronze tier or above and I\'ll add your logo within one business day.',
        },
        {
          q: 'Can I pay via invoice?',
          a: 'Yes — Open Collective provides receipts and invoices automatically. For custom invoicing arrangements, email me directly.',
        },
      ].map(({ q, a }) => (
        <div>
          <dt class="font-semibold text-gray-900 text-sm">{q}</dt>
          <dd class="mt-1 text-sm text-gray-500">{a}</dd>
        </div>
      ))}
    </dl>

    <div class="mt-12 text-center">
      <p class="text-sm text-gray-500 mb-3">Questions about sponsorship or consulting?</p>
      <a
        href="mailto:johnnyazee@gmail.com"
        class="text-sm text-brand-600 hover:text-brand-700 font-medium"
      >
        Email me directly →
      </a>
    </div>
  </section>
</Layout>
