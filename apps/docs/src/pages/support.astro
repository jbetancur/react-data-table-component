---
import Layout from '../layouts/Layout.astro';
import { backers } from '../data/backers';

const GH_SPONSORS = 'https://github.com/sponsors/jbetancur';
const OC_BASE = 'https://opencollective.com/react-data-table-component';

const npmRes = await fetch('https://api.npmjs.org/downloads/point/last-week/react-data-table-component').catch(() => null);
const weeklyDownloads: number = npmRes?.ok ? (await npmRes.json()).downloads : 215000;
const fmt = (n: number) => (n >= 1000 ? `${Math.round(n / 1000)}k` : String(n));
---

<Layout
  title="Support | react-data-table-component"
  description="Priority support plans and sponsorship options for react-data-table-component."
>
  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-6 pt-20 pb-12 text-center">
    <h1 class="text-4xl font-bold tracking-tight text-gray-900">Support &amp; Sponsorship</h1>
    <p class="mt-4 text-lg text-gray-500 max-w-xl mx-auto">
      Actively maintained since 2018 and downloaded ~{fmt(weeklyDownloads)} times a week. Your sponsorship funds bug fixes,
      new features, and keeps pace with the React ecosystem.
    </p>
  </section>

  <!-- Sponsor tiers -->
  <section class="bg-gray-50 py-16">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-2xl font-bold text-gray-900 text-center mb-3">Sponsorship Tiers</h2>
      <p class="text-sm text-gray-500 text-center max-w-xl mx-auto mb-10">
        Bronze buys visibility. Silver and Gold are support plans: your issues jump the queue of a
        library your product already depends on, with written commitments at Gold.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-5">
        {[
          {
            name: '☕ Supporter',
            price: '$5',
            period: '/mo',
            perks: ['Name in README supporters list'],
            ocSlug: 'backer-14044',
          },
          {
            name: '🎗 Backer',
            price: '$20',
            period: '/mo',
            perks: ['Name + link in README', 'Listed in the Backers section on this site'],
            ocSlug: 'sponsor-14045',
          },
          {
            name: '🥉 Bronze',
            price: '$100',
            period: '/mo',
            perks: ['Small logo + link in README', 'Small logo on docs site footer', 'Sponsor credit in release notes'],
            ocSlug: 'bronze-103592',
          },
          {
            name: '🥈 Silver',
            price: '$200',
            period: '/mo',
            perks: ['Everything in Bronze', 'Medium logo on docs site sidebar', 'Priority issue queue: front of the backlog', 'First response within 2 business days'],
            ocSlug: 'silver-103593',
          },
          {
            name: '🥇 Gold',
            price: '$500',
            period: '/mo',
            perks: ['Everything in Silver', 'Large logo: hero spot on reactdatatable.com', 'Top placement in README', '12-month patch window for the previous major', 'Security advisories before public disclosure', 'One compliance questionnaire per year', 'Direct email channel (async, business hours)', 'Limited to 3 sponsors'],
            ocSlug: 'gold-103594',
          },
        ].map(({ name, price, period, perks, ocSlug }) => (
          <div class="bg-white border border-gray-200 rounded-xl p-6 flex flex-col">
            <div class="font-semibold text-gray-900">{name}</div>
            <div class="mt-1 text-2xl font-bold text-gray-900">
              {price}<span class="text-sm font-normal text-gray-400">{period}</span>
            </div>
            <ul class="mt-3 flex-1 space-y-1.5 text-xs text-gray-500">
              {perks.map((p) => (
                <li class="flex items-start gap-1.5">
                  <svg class="mt-0.5 shrink-0 text-brand-500" width="12" height="12" viewBox="0 0 16 16" fill="none">
                    <path d="M3 8l3.5 3.5L13 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {p}
                </li>
              ))}
            </ul>
            <div class="mt-4 space-y-2">
              <a
                href={GH_SPONSORS}
                target="_blank"
                rel="noopener noreferrer"
                class="block text-center bg-brand-600 text-white text-xs font-medium px-3 py-2 rounded-lg hover:bg-brand-700 transition-colors"
              >
                Sponsor on GitHub →
              </a>
              <a
                href={`${OC_BASE}/contribute/${ocSlug}/checkout`}
                target="_blank"
                rel="noopener noreferrer"
                class="block text-center border border-brand-200 text-brand-700 text-xs font-medium px-3 py-2 rounded-lg hover:bg-brand-50 transition-colors"
              >
                Open Collective →
              </a>
            </div>
          </div>
        ))}
      </div>

      <p class="text-center text-xs text-gray-400 mt-6">
        These are honest, written commitments from a solo maintainer: async and business hours. No fake 24/7 SLA.
      </p>

      <!-- One-time -->
      <div class="mt-8 max-w-xl mx-auto bg-white border border-gray-200 rounded-xl p-6 text-center">
        <h3 class="font-semibold text-gray-900 mb-1">One-time donation</h3>
        <p class="text-sm text-gray-500 mb-4">No commitment. Every bit helps.</p>
        <div class="flex flex-wrap items-center justify-center gap-2">
          <a
            href={`${GH_SPONSORS}?frequency=one-time`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block bg-brand-600 text-white text-sm font-medium px-5 py-2 rounded-lg hover:bg-brand-700 transition-colors"
          >
            Sponsor on GitHub →
          </a>
          <a
            href={`${OC_BASE}/contribute/one-time-thanks-103595/checkout`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block border border-brand-200 text-brand-700 text-sm font-medium px-5 py-2 rounded-lg hover:bg-brand-50 transition-colors"
          >
            Open Collective →
          </a>
        </div>
        <p class="mt-3 text-xs text-gray-400">
          Open Collective provides receipts and invoices automatically.
        </p>
      </div>
    </div>
  </section>

  <!-- Backers -->
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h2 id="backers" class="text-2xl font-bold text-gray-900 text-center mb-2">Backers</h2>
    <p class="text-sm text-gray-500 text-center mb-8">
      Thank you to everyone sponsoring at the Backer tier and above.
    </p>
    {backers.length > 0 ? (
      <ul class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm">
        {backers.map(({ name, url }) => (
          <li>
            {url ? (
              <a href={url} target="_blank" rel="noopener noreferrer" class="text-brand-600 hover:text-brand-700 font-medium">{name}</a>
            ) : (
              <span class="text-gray-700 font-medium">{name}</span>
            )}
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-center text-sm text-gray-400">
        <a href="/support" class="text-brand-600 hover:text-brand-700 font-medium">Be the first backer →</a>
      </p>
    )}
  </section>

  <!-- Enterprise support -->
  <section class="max-w-4xl mx-auto px-6 py-16">
    <div class="bg-gray-900 rounded-2xl px-8 py-10 text-center" data-contact data-user="sponsors" data-domain="reactdatatable.com">
      <h2 class="text-2xl font-bold text-white mb-3">Enterprise support</h2>
      <p class="text-sm text-gray-300 max-w-2xl mx-auto mb-6">
        Need commercial support, an SLA, or help with a major version upgrade? I offer direct consulting and
        priority support arrangements for teams that depend on react-data-table-component in production.
      </p>
      <a
        data-contact-link
        href="#"
        class="inline-block bg-white text-gray-900 text-sm font-medium px-5 py-2.5 rounded-lg hover:bg-gray-100 transition-colors"
      >
        Get in touch →
      </a>
    </div>
  </section>

  <!-- Logo placement -->
  <section class="max-w-4xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold text-gray-900 text-center mb-3">Where your logo appears</h2>
    <p class="text-sm text-gray-500 text-center mb-10">Bronze tier and above. Logos link to your site and stay up as long as you sponsor.</p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      <div class="border border-gray-200 rounded-xl p-6">
        <div class="text-xs font-semibold uppercase tracking-wider text-brand-600 mb-2">Bronze · $100/mo</div>
        <h3 class="font-semibold text-gray-900 mb-1">Docs site footer</h3>
        <p class="text-xs text-gray-500 mb-4">Small logo in the footer of every page on reactdatatable.com, seen by every developer reading the docs.</p>
        <div class="bg-gray-50 rounded-lg p-3 border border-gray-100 text-xs text-gray-400 font-mono">
          <div class="border-t border-gray-200 pt-2 mt-2 flex items-center gap-2">
            <div class="w-8 h-4 bg-gray-200 rounded" />
            <span>Apache 2.0 licensed · GitHub · Built with Astro</span>
          </div>
          <div class="flex items-center gap-2 mt-1 text-[10px]">
            <div class="w-8 h-4 bg-brand-100 rounded border border-brand-200 flex items-center justify-center text-brand-400">logo</div>
            <span class="text-gray-300">← your logo here</span>
          </div>
        </div>
      </div>

      <div class="border border-gray-200 rounded-xl p-6">
        <div class="text-xs font-semibold uppercase tracking-wider text-brand-600 mb-2">Silver · $200/mo</div>
        <h3 class="font-semibold text-gray-900 mb-1">Docs site sidebar</h3>
        <p class="text-xs text-gray-500 mb-4">Medium logo in the sidebar of every docs page, visible to developers actively reading the documentation.</p>
        <div class="bg-gray-50 rounded-lg p-3 border border-gray-100 text-xs text-gray-400 font-mono">
          <div class="flex gap-2">
            <div class="w-16 border-r border-gray-200 pr-2 space-y-1">
              <div class="w-full h-2 bg-gray-200 rounded" />
              <div class="w-full h-2 bg-gray-200 rounded" />
              <div class="w-12 h-6 bg-brand-100 rounded border border-brand-200 flex items-center justify-center text-[9px] text-brand-400 mt-2">logo</div>
            </div>
            <div class="flex-1 space-y-1">
              <div class="w-full h-2 bg-gray-200 rounded" />
              <div class="w-3/4 h-2 bg-gray-200 rounded" />
            </div>
          </div>
        </div>
      </div>

      <div class="border-2 border-brand-200 rounded-xl p-6 relative">
        <div class="absolute -top-3 left-4 bg-brand-600 text-white text-[10px] font-semibold px-2 py-0.5 rounded-full">Most visible</div>
        <div class="text-xs font-semibold uppercase tracking-wider text-brand-600 mb-2">Gold · $500/mo</div>
        <h3 class="font-semibold text-gray-900 mb-1">Homepage hero</h3>
        <p class="text-xs text-gray-500 mb-4">Large logo in the sponsors section of the homepage, the highest-traffic page, seen by every new visitor. Limited to 3.</p>
        <div class="bg-gray-50 rounded-lg p-3 border border-gray-100 text-xs text-gray-400 font-mono">
          <div class="text-center space-y-1">
            <div class="text-[10px] text-gray-300">Sponsors</div>
            <div class="flex items-center justify-center gap-2">
              <div class="w-16 h-8 bg-brand-100 rounded border border-brand-200 flex items-center justify-center text-[9px] text-brand-400">your logo</div>
              <div class="w-10 h-6 bg-gray-200 rounded" />
            </div>
          </div>
        </div>
      </div>
    </div>

    <p class="text-center text-xs text-gray-400 mt-6">
      All tiers also include your name and link in the GitHub README, seen by developers browsing the repo.
    </p>
  </section>

  <!-- FAQ -->
  <section class="max-w-2xl mx-auto px-6 py-16">
    <h2 class="text-xl font-bold text-gray-900 mb-8 text-center">Common questions</h2>
    <dl class="space-y-6">
      {[
        {
          q: 'Does the library stay free?',
          a: 'Yes, always. The core library is Apache 2.0 licensed. Sponsorship funds maintenance; it doesn\'t change what\'s free.',
        },
        {
          q: 'Can I get help with a complex integration?',
          a: 'Yes, email me directly to discuss one-off consulting. I\'m available for integrations, performance issues, and major version upgrades.',
        },
        {
          q: 'How does logo placement work?',
          a: 'Email me after subscribing at the Bronze tier or above and I\'ll add your logo within one business day.',
        },
        {
          q: 'Can I pay via invoice?',
          a: 'Yes, Open Collective provides receipts and invoices automatically. For custom invoicing arrangements, email me directly.',
        },
      ].map(({ q, a }) => (
        <div>
          <dt class="font-semibold text-gray-900 text-sm">{q}</dt>
          <dd class="mt-1 text-sm text-gray-500">{a}</dd>
        </div>
      ))}
    </dl>

    <div class="mt-12 text-center" data-contact data-user="sponsors" data-domain="reactdatatable.com">
      <p class="text-sm text-gray-500 mb-3">Questions about sponsorship or consulting?</p>
      <div class="inline-flex items-center gap-2">
        <a
          data-contact-link
          href="#"
          class="text-sm text-brand-600 hover:text-brand-700 font-medium"
        >
          Email me directly →
        </a>
        <button
          data-contact-copy
          type="button"
          aria-label="Copy email address"
          class="hidden items-center gap-1 text-xs text-gray-400 hover:text-gray-600 border border-gray-200 rounded-md px-2 py-1 transition-colors"
        >
          <svg data-copy-icon width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <rect x="4" y="4" width="9" height="9" rx="1.5"/>
            <path d="M3 11H2.5A1.5 1.5 0 0 1 1 9.5v-7A1.5 1.5 0 0 1 2.5 1h7A1.5 1.5 0 0 1 11 2.5V3"/>
          </svg>
          <span data-copy-label>Copy</span>
        </button>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll<HTMLElement>('[data-contact]').forEach((root) => {
      const addr = `${root.dataset.user}@${root.dataset.domain}`;
      const link = root.querySelector<HTMLAnchorElement>('[data-contact-link]');
      const copy = root.querySelector<HTMLButtonElement>('[data-contact-copy]');
      const label = root.querySelector<HTMLElement>('[data-copy-label]');

      if (link) link.href = `mailto:${addr}`;

      if (copy && label && navigator.clipboard) {
        copy.classList.remove('hidden');
        copy.classList.add('inline-flex');
        copy.addEventListener('click', async () => {
          await navigator.clipboard.writeText(addr);
          const original = label.textContent;
          label.textContent = 'Copied!';
          setTimeout(() => {
            label.textContent = original;
          }, 2000);
        });
      }
    });
  </script>
</Layout>
