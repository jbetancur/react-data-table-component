---
import { Code } from 'astro:components';
import Layout from '../layouts/Layout.astro';
import LiveDemo from '../components/LiveDemo.tsx';
import { backers } from '../data/backers';

const [npmRes, ghRes] = await Promise.allSettled([
  fetch('https://api.npmjs.org/downloads/point/last-week/react-data-table-component'),
  fetch('https://api.github.com/repos/jbetancur/react-data-table-component'),
]);

const weeklyDownloads: number =
  npmRes.status === 'fulfilled' && npmRes.value.ok
    ? (await npmRes.value.json()).downloads
    : 215000;

const stars: number =
  ghRes.status === 'fulfilled' && ghRes.value.ok
    ? (await ghRes.value.json()).stargazers_count
    : 2000;

function fmt(n: number): string {
  if (n >= 1000) return `${Math.floor(n / 1000)}k+`;
  return String(n);
}
---

<Layout title="react-data-table-component: Working table in 10 lines" description="A fast, accessible React data table with sorting, pagination, row selection, expandable rows, and theming. Zero peer dependencies. Working table in 10 lines.">
	<!-- Hero -->
	<section class="max-w-7xl mx-auto px-6 pt-20 pb-16 text-center">
		<div class="flex items-center justify-center gap-3 mb-6 flex-wrap">
			<div
				class="inline-flex items-center gap-2 bg-brand-50 text-brand-700 text-xs font-medium px-3 py-1 rounded-full border border-brand-100"
			>
				v8.0 · No peer deps · React 18+
			</div>
			<a
				href="/docs/changelog"
				class="inline-flex items-center gap-1 text-xs font-medium text-brand-600 hover:text-brand-700 hover:underline"
			>
				What's new in v8 →
			</a>
		</div>

		<h1 class="text-5xl font-bold tracking-tight text-gray-900 max-w-3xl mx-auto leading-tight">
			A working data table<br />
			<span class="text-brand-600">in 10 lines of React</span>
		</h1>

		<p class="mt-5 text-lg text-gray-500 max-w-xl mx-auto">
			Sorting, pagination, row selection, theming, and expandable rows, all included. No boilerplate. No CSS
			file. No paid tier.
		</p>

		<div class="mt-8 flex items-center justify-center gap-4">
			<a
				href="/docs/getting-started"
				class="bg-brand-600 text-white px-5 py-2.5 rounded-lg font-medium hover:bg-brand-700 shadow-sm"
			>
				Get started →
			</a>
			<a
				href="https://github.com/jbetancur/react-data-table-component"
				target="_blank"
				rel="noopener noreferrer"
				class="text-gray-600 px-5 py-2.5 rounded-lg font-medium hover:text-gray-900 border border-gray-200 hover:border-gray-300"
			>
				GitHub
			</a>
		</div>

		<!-- Install snippet -->
		<div class="mt-8 inline-flex items-center gap-4 bg-gray-950 text-gray-100 rounded-lg px-5 py-3 font-mono text-sm group relative">
			<span><span class="text-gray-500">$</span> npm install react-data-table-component</span>
			<button
				id="install-copy-btn"
				aria-label="Copy install command"
				class="flex items-center gap-1 text-xs text-gray-400 hover:text-white transition-colors"
			>
				<svg id="install-icon-copy" width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
					<rect x="4" y="4" width="9" height="9" rx="1.5"/>
					<path d="M3 11H2.5A1.5 1.5 0 0 1 1 9.5v-7A1.5 1.5 0 0 1 2.5 1h7A1.5 1.5 0 0 1 11 2.5V3"/>
				</svg>
				<svg id="install-icon-check" class="hidden" width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<polyline points="2 8 6 12 14 4"/>
				</svg>
			</button>
		</div>
		<script>
			document.getElementById('install-copy-btn')?.addEventListener('click', async () => {
				await navigator.clipboard.writeText('npm install react-data-table-component');
				document.getElementById('install-icon-copy')?.classList.add('hidden');
				document.getElementById('install-icon-check')?.classList.remove('hidden');
				setTimeout(() => {
					document.getElementById('install-icon-copy')?.classList.remove('hidden');
					document.getElementById('install-icon-check')?.classList.add('hidden');
				}, 2000);
			});
		</script>

		<!-- Social proof stats -->
		<div class="mt-10 flex items-center justify-center gap-8 flex-wrap text-center">
			<div>
				<div class="text-2xl font-bold text-gray-900">{fmt(weeklyDownloads)}</div>
				<div class="text-xs text-gray-400 mt-0.5">weekly downloads</div>
			</div>
			<div class="w-px h-8 bg-gray-200 hidden sm:block"></div>
			<div>
				<a href="https://github.com/jbetancur/react-data-table-component" target="_blank" rel="noopener noreferrer" class="hover:opacity-80 transition-opacity">
					<div class="text-2xl font-bold text-gray-900">{fmt(stars)}</div>
					<div class="text-xs text-gray-400 mt-0.5">GitHub stars</div>
				</a>
			</div>
			<div class="w-px h-8 bg-gray-200 hidden sm:block"></div>
			<div>
				<div class="text-2xl font-bold text-gray-900">2018</div>
				<div class="text-xs text-gray-400 mt-0.5">actively maintained since</div>
			</div>
		</div>
	</section>

	<!-- Live demo -->
	<section class="max-w-5xl mx-auto px-6 pb-20">
		<LiveDemo client:load />
	</section>

	<!-- 10-line code sample -->
	<section class="bg-gray-950 py-20">
		<div class="max-w-3xl mx-auto px-6">
			<div class="text-center mb-8">
				<h2 class="text-2xl font-bold text-white">Working table in 10 lines</h2>
				<p class="text-gray-400 mt-2 text-sm">No imports, no config, no CSS file. Just data and columns.</p>
			</div>
			<Code
				code={`import DataTable from 'react-data-table-component';

const columns = [
  { name: 'Name',   selector: row => row.name,   sortable: true },
  { name: 'Role',   selector: row => row.role },
  { name: 'Salary', selector: row => row.salary, right: true },
];

export default function App() {
  return <DataTable columns={columns} data={data} pagination />;
}`}
				lang="tsx"
				theme="catppuccin-macchiato"
				defaultColor={false}
				class="rounded-xl text-sm leading-relaxed overflow-x-auto p-6"
			/>
		</div>
	</section>

	<!-- Feature grid -->
	<section class="max-w-7xl mx-auto px-6 py-20">
		<h2 class="text-2xl font-bold text-center text-gray-900 mb-12">Everything included, nothing to configure</h2>
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
			{
				[
					{
						icon: '⟨/⟩',
						title: 'Fully typed',
						desc: 'Generic column types inferred from your data. All props exported for easy import.',
					},
					{
						icon: '🎨',
						title: '5 built-in themes',
						desc: 'Default, Material, Rounded, Catppuccin, AG Grid, all with full dark mode. Bring your own via createTheme().',
					},
					{
						icon: '↕',
						title: 'Sort & paginate',
						desc: 'Client-side and server-side sorting. Configurable pagination or custom pagination components.',
					},
					{
						icon: '☑',
						title: 'Row selection',
						desc: 'Multi-select with checkboxes. Select all, per-page, persistent across pages. Controlled via ref.',
					},
					{
						icon: '▶',
						title: 'Expandable rows',
						desc: 'Render any component inside an expandable detail panel. Animate open/close with a single prop.',
					},
					{
						icon: '⌕',
						title: 'Column filtering',
						desc: 'Per-column filter inputs for text, number, and select. Client-side or hook into your own server search.',
					},
					{
						icon: '⊞',
						title: 'Column groups',
						desc: 'Span headers across multiple columns. Useful for financial and analytical tables.',
					},
					{
						icon: '↔',
						title: 'Resizable columns',
						desc: 'Drag column edges to resize. Widths preserved in state, serializable for persistence.',
					},
					{
						icon: '▲',
						title: 'SSR & Next.js ready',
						desc: 'Works in Next.js App Router, Remix, and Astro. No useLayoutEffect warnings. Ships "use client" automatically.',
					},
				].map(({ icon, title, desc }) => (
					<div class="border border-gray-100 rounded-xl p-5 hover:border-brand-200 hover:shadow-sm transition-all">
						<div class="text-2xl mb-3">{icon}</div>
						<h3 class="font-semibold text-gray-900 mb-1">{title}</h3>
						<p class="text-sm text-gray-500">{desc}</p>
					</div>
				))
			}
		</div>
	</section>

	<!-- Comparison table -->
	<section class="bg-gray-50 py-20">
		<div class="max-w-4xl mx-auto px-6">
			<h2 class="text-2xl font-bold text-center text-gray-900 mb-3">How it compares</h2>
			<p class="text-center text-sm text-gray-500 max-w-2xl mx-auto mb-10">
				All four are solid choices. The difference is how much you assemble yourself. This library optimizes
				for a styled, working table with the least code, not for the largest feature surface.
			</p>
			<div class="overflow-x-auto">
				<table
					class="w-full text-sm border-collapse bg-white rounded-xl overflow-hidden shadow-sm border border-gray-200"
				>
					<thead>
						<tr class="bg-gray-50 border-b border-gray-200">
							<th class="text-left px-4 py-3 text-gray-600 font-medium"></th>
							<th class="text-center px-4 py-3 text-gray-600 font-medium">TanStack Table</th>
							<th class="text-center px-4 py-3 text-gray-600 font-medium">AG Grid Community</th>
							<th class="text-center px-4 py-3 text-gray-600 font-medium">MUI X Data Grid</th>
							<th class="text-center px-4 py-3 text-brand-700 font-semibold bg-brand-50">This library</th>
						</tr>
					</thead>
					<tbody>
						{
							[
								['Approach', 'Headless', 'Full data grid', 'Full data grid', 'Full component'],
								['Styled table out of the box', 'You build the UI', '✓', '✓', '✓'],
								['Sorting, pagination & selection UI', 'State only', '✓', '✓', '✓'],
								['Expandable row panels', 'State only', 'Enterprise tier', 'Pro tier', '✓'],
								['Dark mode & themes', 'Bring your own', '✓ built-in', 'Via MUI theme', '5 built-in, incl. Material'],
								['Requires a UI framework', 'No', 'No', '@mui/material + Emotion', 'No'],
								['Size (min+gzip)', '~15 KB', '~338 KB', '~117 KB + MUI', '~35 KB'],
								['Paid tiers', 'None', 'Enterprise', 'Pro & Premium', 'None'],
							].map(([feature, tanstack, ag, mui, rdt], i) => (
								<tr class={i % 2 === 0 ? 'bg-white' : 'bg-gray-50/50'}>
									<td class="px-4 py-2.5 text-gray-700 font-medium">{feature}</td>
									<td class="px-4 py-2.5 text-center text-gray-500">{tanstack}</td>
									<td class="px-4 py-2.5 text-center text-gray-500">{ag}</td>
									<td class="px-4 py-2.5 text-center text-gray-500">{mui}</td>
									<td class="px-4 py-2.5 text-center text-brand-700 font-medium bg-brand-50/30">{rdt}</td>
								</tr>
							))
						}
					</tbody>
				</table>
				<p class="text-center text-sm text-gray-500 mt-6 max-w-2xl mx-auto">
					They're all great at what they do. This one's for when you want a styled, sortable,
					paginated table working today, with nothing to configure and no tier to upgrade to.
				</p>
				<p class="text-center text-xs text-gray-400 mt-1">
					Sizes are min+gzip via Bundlephobia, July 2026 (TanStack v8.21, AG Grid v36, MUI X v9.8).
				</p>
			</div>
		</div>
	</section>

	<!-- Sponsors -->
	<section class="max-w-4xl mx-auto px-6 py-20 text-center">
		<h2 class="text-xl font-semibold text-gray-900 mb-2">Sponsors</h2>
		<p class="text-sm text-gray-500 mb-8">
			Actively maintained since 2018. If your team ships products with it, consider sponsoring. It funds bug
			fixes and keeps pace with the React ecosystem.
		</p>

		<!-- Logo slot, add more logos as Bronze+ sponsors sign on -->
		<div class="flex flex-wrap items-center justify-center gap-6 mb-8">
			<a
				href="/support"
				class="flex items-center justify-center gap-2 h-16 px-6 border-2 border-dashed border-gray-200 rounded-xl text-sm text-gray-400 hover:border-brand-300 hover:text-brand-500 transition-colors"
			>
				<span class="text-lg">♡</span> Be the first logo sponsor
			</a>
		</div>

		{backers.length > 0 && (
			<p class="text-sm text-gray-500 mb-8">
				Thank you to our backers for their recurring support:{' '}
				{backers.map(({ name, url }, i) => (
					<>
						{i > 0 && ', '}
						{url ? (
							<a href={url} target="_blank" rel="noopener noreferrer" class="text-brand-600 hover:text-brand-700 font-medium">{name}</a>
						) : (
							<span class="text-gray-700 font-medium">{name}</span>
						)}
					</>
				))}
				. <a href="/support#backers" class="text-brand-600 hover:text-brand-700 font-medium">See all →</a>
			</p>
		)}

		<div class="flex items-center justify-center gap-4">
			<a
				href="/support"
				class="bg-brand-600 text-white px-5 py-2 rounded-lg font-medium hover:bg-brand-700 shadow-sm text-sm"
			>
				Become a sponsor
			</a>
			<a
				href="/support"
				class="text-sm text-gray-500 hover:text-gray-700 border border-gray-200 px-5 py-2 rounded-lg hover:border-gray-300"
			>
				View sponsorship tiers →
			</a>
		</div>
	</section>

	<!-- CTA -->
	<section class="bg-gray-50 py-20">
		<div class="max-w-3xl mx-auto px-6 text-center">
			<h2 class="text-3xl font-bold text-gray-900 mb-4">Ready to ship?</h2>
			<p class="text-gray-500 mb-8">One install. No config. Working table in 10 lines.</p>
			<a
				href="/docs/getting-started"
				class="bg-brand-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-brand-700 shadow-sm text-lg"
			>
				Read the docs →
			</a>
		</div>
	</section>
</Layout>
