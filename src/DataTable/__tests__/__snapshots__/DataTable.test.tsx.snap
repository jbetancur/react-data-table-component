  style="--rdt-color-text-primary: rgba(0, 0, 0, 0.87); --rdt-color-text-secondary: rgba(0, 0, 0, 0.54); --rdt-color-text-disabled: rgba(0, 0, 0, 0.38); --rdt-color-bg: #FFFFFF; --rdt-color-context-bg: #e3f2fd; --rdt-color-context-text: rgba(0, 0, 0, 0.87); --rdt-color-divider: rgba(0,0,0,.12); --rdt-color-btn: rgba(0,0,0,.54); --rdt-color-btn-focus: rgba(0,0,0,.12); --rdt-color-btn-hover: rgba(0,0,0,.12); --rdt-color-btn-disabled: rgba(0, 0, 0, .18); --rdt-color-selected: #e3f2fd; --rdt-color-selected-text: rgba(0, 0, 0, 0.87); --rdt-color-highlight: #EEEEEE; --rdt-color-highlight-text: rgba(0, 0, 0, 0.87); --rdt-color-striped: #FAFAFA; --rdt-color-striped-text: rgba(0, 0, 0, 0.87);"
>
  <div
    class="rdt_TableHeader"
    style="font-size: 22px; color: rgba(0, 0, 0, 0.87); background-color: rgb(255, 255, 255); min-height: 56px; padding-left: 16px; padding-right: 8px;"
  >
    <div
      class="rdt_header"
    >
      <div
        class="rdt_headerTitle"
      >
        whoa!
      </div>
      <div
        class="rdt_contextMenu rdt_contextMenuVisible"
        style="background-color: rgb(227, 242, 253); font-size: 18px; font-weight: 400; color: rgba(0, 0, 0, 0.87); padding-left: 16px; padding-right: 8px; transform: translate3d(0, 0, 0); transition-duration: 125ms; transition-timing-function: cubic-bezier(0, 0, 0.2, 1); will-change: transform;"
      >
        <div
          class="rdt_contextTitle"
        >
          1 artículo seleccionada
        </div>
        <div
          class="rdt_contextActions"
        />
      </div>
    </div>
  </div>
  <div
    class="rdt_responsiveWrapper rdt_responsiveWrapperScroll"
  >
    <div
      class="rdt_wrapper"
      style="display: table;"
    >
      <div
        aria-busy="false"
        class="rdt_table rdt_Table"
        id=":r4d:"
        role="table"
        style="color: rgba(0, 0, 0, 0.87); background-color: rgb(255, 255, 255);"
      >
        <div
          class="rdt_head rdt_TableHead"
          role="rowgroup"
          style="color: rgba(0, 0, 0, 0.87); font-size: 12px; font-weight: 500;"
        >
          <div
            class="rdt_headRow rdt_TableHeadRow"
            role="row"
            style="background-color: rgb(255, 255, 255); min-height: 52px; border-bottom-width: 1px; border-bottom-color: rgba(0, 0, 0, 0.12); border-bottom-style: solid;"
          >
            <div
              class="rdt_cellBase rdt_cellBaseHead rdt_cellNoPadding rdt_TableCol rdt_columnCheckbox"
            >
              <input
                aria-label="select-all-rows"
                name="select-all-rows"
                style="font-size: 18px; cursor: pointer; padding: 0px; margin-top: 1px; vertical-align: middle; position: relative;"
                type="checkbox"
              />
            </div>
            <div
              class="rdt_cellBase rdt_cellBaseHead rdt_TableCol"
              data-column-id="1"
              style="flex-grow: 1; flex-shrink: 0; flex-basis: 0px; max-width: 100%; min-width: 100px;"
            >
              <div
                class="rdt_TableCol_Sortable rdt_columnSortable"
                data-column-id="1"
                data-sort-id="1"
                role="columnheader"
                tabindex="-1"
              >
                <div
                  class="rdt_columnText"
                  data-column-id="1"
                >
                  Test
                </div>
              </div>
            </div>
          </div>
        </div>
        <div
          class="rdt_body rdt_TableBody"
          role="rowgroup"
        >
          <div
            class="rdt_TableRow rdt_row"
            id="row-1"
            role="row"
            style="font-size: 13px; font-weight: 400; color: rgba(0, 0, 0, 0.87); background-color: rgb(255, 255, 255); min-height: 48px; border-bottom-style: solid; border-bottom-width: 1px; border-bottom-color: rgba(0, 0, 0, 0.12);"
          >
            <div
              class="rdt_cellBase rdt_cellNoPadding rdt_TableCell rdt_cellCheckbox"
            >
              <input
                aria-label="select-row-1"
                name="select-row-1"
                style="font-size: 18px; cursor: pointer; padding: 0px; margin-top: 1px; vertical-align: middle; position: relative;"
                type="checkbox"
              />
            </div>
            <div
              class="rdt_cellBase rdt_TableCell"
              data-column-id="1"
              data-tag="allowRowEvents"
              id="cell-1-1"
              role="cell"
              style="word-break: break-word; flex-grow: 1; flex-shrink: 0; flex-basis: 0px; max-width: 100%; min-width: 100px;"
            >
              <div
                data-tag="allowRowEvents"
                style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"
              >
                Apple
              </div>
            </div>
          </div>
          <div
            class="rdt_TableRow rdt_row"
            id="row-2"
            role="row"
            style="font-size: 13px; font-weight: 400; color: rgba(0, 0, 0, 0.87); background-color: rgb(255, 255, 255); min-height: 48px; border-bottom-style: solid; border-bottom-width: 1px; border-bottom-color: rgba(0, 0, 0, 0.12);"
          >
            <div
              class="rdt_cellBase rdt_cellNoPadding rdt_TableCell rdt_cellCheckbox"
            >
              <input
                aria-label="select-row-2"
                name="select-row-2"
                style="font-size: 18px; cursor: pointer; padding: 0px; margin-top: 1px; vertical-align: middle; position: relative;"
                type="checkbox"
              />
            </div>
            <div
              class="rdt_cellBase rdt_TableCell"
              data-column-id="1"
              data-tag="allowRowEvents"
              id="cell-1-2"
              role="cell"
              style="word-break: break-word; flex-grow: 1; flex-shrink: 0; flex-basis: 0px; max-width: 100%; min-width: 100px;"
            >
              <div
                data-tag="allowRowEvents"
                style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"
              >
                Zuchinni
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
`;

