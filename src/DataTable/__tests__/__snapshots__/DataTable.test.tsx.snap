  style="--rdt-color-text-primary: rgba(0, 0, 0, 0.87); --rdt-color-text-secondary: rgba(0, 0, 0, 0.54); --rdt-color-text-disabled: rgba(0, 0, 0, 0.38); --rdt-color-bg: #FFFFFF; --rdt-color-context-bg: #e3f2fd; --rdt-color-context-text: rgba(0, 0, 0, 0.87); --rdt-color-divider: rgba(0,0,0,.12); --rdt-color-btn: rgba(0,0,0,.54); --rdt-color-btn-focus: rgba(0,0,0,.12); --rdt-color-btn-hover: rgba(0,0,0,.12); --rdt-color-btn-disabled: rgba(0, 0, 0, .18); --rdt-color-selected: #e3f2fd; --rdt-color-selected-text: rgba(0, 0, 0, 0.87); --rdt-color-highlight: #EEEEEE; --rdt-color-highlight-text: rgba(0, 0, 0, 0.87); --rdt-color-striped: #FAFAFA; --rdt-color-striped-text: rgba(0, 0, 0, 0.87);"
>
  <div
    class="rdt_responsiveWrapper rdt_responsiveWrapperScroll"
  >
    <div
      class="rdt_wrapper"
      style="display: table;"
    >
      <div
        aria-busy="false"
        class="rdt_table rdt_Table"
        id=":ro:"
        role="table"
        style="color: rgba(0, 0, 0, 0.87); background-color: rgb(255, 255, 255);"
      >
        <div
          class="rdt_head rdt_TableHead"
          role="rowgroup"
          style="color: rgba(0, 0, 0, 0.87); font-size: 12px; font-weight: 500;"
        >
          <div
            class="rdt_headRow rdt_TableHeadRow"
            role="row"
            style="background-color: rgb(255, 255, 255); min-height: 52px; border-bottom-width: 1px; border-bottom-color: rgba(0, 0, 0, 0.12); border-bottom-style: solid;"
          >
            <div
              class="rdt_cellBase rdt_cellBaseHead rdt_TableCol"
              data-column-id="1"
              style="flex-grow: 1; flex-shrink: 0; flex-basis: 0px; max-width: 600px; min-width: 100px;"
            >
              <div
                class="rdt_TableCol_Sortable rdt_columnSortable"
                data-column-id="1"
                data-sort-id="1"
                role="columnheader"
                tabindex="-1"
              >
                <div
                  class="rdt_columnText"
                  data-column-id="1"
                >
                  Test
                </div>
              </div>
            </div>
          </div>
        </div>
        <div
          class="rdt_body rdt_TableBody"
          role="rowgroup"
        >
          <div
            class="rdt_TableRow rdt_row"
            id="row-1"
            role="row"
            style="font-size: 13px; font-weight: 400; color: rgba(0, 0, 0, 0.87); background-color: rgb(255, 255, 255); min-height: 48px; border-bottom-style: solid; border-bottom-width: 1px; border-bottom-color: rgba(0, 0, 0, 0.12);"
          >
            <div
              class="rdt_cellBase rdt_TableCell"
              data-column-id="1"
              data-tag="allowRowEvents"
              id="cell-1-1"
              role="cell"
              style="word-break: break-word; flex-grow: 1; flex-shrink: 0; flex-basis: 0px; max-width: 600px; min-width: 100px;"
            >
              <div
                data-tag="allowRowEvents"
                style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"
              >
                Apple
              </div>
            </div>
          </div>
          <div
            class="rdt_TableRow rdt_row"
            id="row-2"
            role="row"
            style="font-size: 13px; font-weight: 400; color: rgba(0, 0, 0, 0.87); background-color: rgb(255, 255, 255); min-height: 48px; border-bottom-style: solid; border-bottom-width: 1px; border-bottom-color: rgba(0, 0, 0, 0.12);"
          >
            <div
              class="rdt_cellBase rdt_TableCell"
              data-column-id="1"
              data-tag="allowRowEvents"
              id="cell-1-2"
              role="cell"
              style="word-break: break-word; flex-grow: 1; flex-shrink: 0; flex-basis: 0px; max-width: 600px; min-width: 100px;"
            >
              <div
                data-tag="allowRowEvents"
                style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;"
              >
                Zuchinni
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
`;

